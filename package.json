{
  "name": "claycli",
  "version": "5.1.0-0",
  "description": "A command-line interface for Clay",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "preferGlobal": true,
  "bin": {
    "clay": "dist/cli/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && cp package.json dist/",
    "lint": "eslint lib cli index.ts",
    "test": "npm run lint && jest",
    "type-check": "tsc --noEmit",
    "coveralls": "cat ./coverage/lcov.info | coveralls",
    "release": "./.circleci/scripts/release.sh",
    "watch": "jest --watch",
    "prepublishOnly": "npm run build"
  },
  "jest": {
    "automock": false,
    "testEnvironment": "node",
    "testEnvironmentOptions": {
      "url": "http://localhost/"
    },
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "collectCoverage": true,
    "collectCoverageFrom": [
      "**/*.{js,ts}",
      "!lib/reporters/**",
      "!**/node_modules/**",
      "!**/cli/**",
      "!lib/cmd/compile/**",
      "!**/coverage/**",
      "!**/index.js",
      "!lib/gulp-plugins/gulp-newer/*.js",
      "!website/**"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "lib/gulp-plugins/gulp-newer/"
    ],
    "setupFiles": [
      "./setup-jest.js"
    ]
  },
  "pre-push": [
    "lint"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nymag/clay-cli.git"
  },
  "keywords": [
    "clay",
    "cli"
  ],
  "author": "New York Media",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nymag/clay-cli/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://github.com/nymag/clay-cli#readme",
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.1",
    "coveralls": "^3.0.0",
    "eslint": "^9.39.3",
    "globals": "^17.3.0",
    "jest": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-mock-console": "^2.0.0",
    "mock-fs": "^5.5.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "@babel/core": "^7.24.3",
    "@babel/preset-env": "^7.24.3",
    "amphora-fs": "^1.0.2",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^10.0.0",
    "babel-plugin-lodash": "^3.3.4",
    "case-sensitive-paths-webpack-plugin": "^2.4.0",
    "chalk": "^4.1.0",
    "chokidar": "^3.5.1",
    "clay-log": "^1.3.0",
    "clayhandlebars": "5",
    "clayutils": "^3.0.0",
    "css-loader": "^7.1.4",
    "date-fns": "^2.17.0",
    "dependency-tree": "^8.0.0",
    "detective-postcss": "^4.0.0",
    "dotenv-webpack": "^8.1.1",
    "escape-quotes": "^1.0.2",
    "event-stream": "4.0.1",
    "exports-loader": "^3.0.0",
    "fs-extra": "^11.3.0",
    "get-stdin": "^8.0.0",
    "glob": "^7.1.6",
    "gulp": "^4.0.2",
    "gulp-babel": "^8.0.0",
    "gulp-changed": "^4.0.2",
    "gulp-concat": "^2.6.1",
    "gulp-cssmin": "^0.2.0",
    "gulp-group-concat": "^1.1.6",
    "gulp-if": "^3.0.0",
    "gulp-postcss": "^10.0.0",
    "gulp-rename": "^2.0.0",
    "gulp-replace": "^1.0.0",
    "highland": "^2.13.0",
    "home-config": "^0.1.0",
    "imports-loader": "^2.0.0",
    "js-yaml": "^4.0.0",
    "lodash": "^4.17.5",
    "mini-css-extract-plugin": "^2.10.0",
    "moment": "^2.29.1",
    "moment-locales-webpack-plugin": "^1.2.0",
    "nyansole": "^0.5.1",
    "path-browserify": "^1.0.1",
    "plugin-error": "^1.0.1",
    "pluralize": "^8.0.0",
    "postcss": "^8.5.6",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.1",
    "postcss-mixins": "^10.0.1",
    "postcss-nested": "^6.2.0",
    "postcss-simple-vars": "^7.0.1",
    "split-lines": "^2.0.0",
    "string-replace-async": "^2.0.0",
    "style-loader": "^4.0.0",
    "terminal-logger": "^0.2.3",
    "terser": "^5.46.0",
    "uglify-js": "^3.4.6",
    "update-notifier": "^5.1.0",
    "vue-loader": "^15.11.1",
    "webpack": "^5.105.2",
    "webpack-assets-manifest": "^6.5.0",
    "webpack-chain": "^6.5.1",
    "yargs": "^17.7.0"
  },
  "peerDependencies": {
    "clayhandlebars": "5"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.2"
  }
}
